{
  "name": "axl-pubsub",
  "version": "0.1.1",
  "description": "Topic-based pub/sub gossip on top of Gensyn AXL.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ophelios-studio/axl-pubsub.git"
  },
  "homepage": "https://github.com/ophelios-studio/axl-pubsub#readme",
  "bugs": {
    "url": "https://github.com/ophelios-studio/axl-pubsub/issues"
  },
  "keywords": [
    "axl",
    "gensyn",
    "pubsub",
    "gossip",
    "yggdrasil",
    "p2p",
    "ed25519"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "integration:up": "make -C test/integration/compose up",
    "integration:down": "make -C test/integration/compose down",
    "integration:logs": "make -C test/integration/compose logs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm",
      "cjs"
    ],
    "dts": true,
    "clean": true,
    "sourcemap": true
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
